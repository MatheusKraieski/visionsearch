rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: suppliers
    // Fields:
    //   - name: string (required)
    //   - contact: string (required)
    //   - address: string (optional)
    //
    // Collection: products
    // Fields:
    //   - name: string (required)
    //   - code: string (required)
    //   - price: number (required)
    //   - imageUrl: string (optional)
    //   - supplierId: string (required)
    //   - category: string (optional)
    //   - tags: list (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "matheus.kraieski@adsplay.com.br");
    }

    // Domain Validators
    function isValidSupplier(data) {
      return data.keys().hasAll(['name', 'contact']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.contact is string && data.contact.size() > 0 && data.contact.size() < 200;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'code', 'price', 'supplierId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.code is string && data.code.size() > 0 && data.code.size() < 50 &&
             data.price is number && data.price >= 0 &&
             data.supplierId is string && data.supplierId.size() > 0;
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidSupplier(request.resource.data);
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
