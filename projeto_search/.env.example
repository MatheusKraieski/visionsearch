# Copie para .env.local e preencha com suas credenciais do Supabase
# Nunca commite o .env.local

# Supabase — obtenha em: supabase.com → seu projeto → Settings → API
VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY="sua_anon_key_aqui"

# Gemini AI — obtenha em: aistudio.google.com/apikey
GEMINI_API_KEY="sua_gemini_key_aqui"
